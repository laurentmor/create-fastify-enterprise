# Copy to .env for local development.
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/__PROJECT_NAME__

# CORS - comma separated list of allowed origins, or * for all
CORS_ORIGIN=*

# Rate limiting
RATE_LIMIT_MAX=200
RATE_LIMIT_WINDOW=1 minute
