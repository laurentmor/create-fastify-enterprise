{
  "name": "create-fastify-enterprise",
  "version": "0.1.0",
  "description": "Scaffold enterprise-grade Fastify + TypeBox + MongoDB/Mongoose services with CI/CD, OpenAPI, Vault-ready config and SPDX/REUSE compliance out of the box.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "create-fastify-enterprise": "./dist/index.js"
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "bun": ">=1.1.0",
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target node --format esm && chmod +x dist/index.js",
    "dev": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "prepare": "husky"
  },
  "dependencies": {
    "@clack/prompts": "^0.8.2",
    "commander": "^12.1.0",
    "picocolors": "^1.1.1",
    "validate-npm-package-name": "^5.0.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@types/node": "^22.10.2",
    "@types/validate-npm-package-name": "^4.0.2",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "@eslint/js": "^9.17.0",
    "typescript-eslint": "^8.18.1",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.13.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "prettier": "^3.8.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "keywords": [
    "fastify",
    "typebox",
    "mongodb",
    "mongoose",
    "generator",
    "scaffold",
    "cli",
    "bun",
    "enterprise",
    "openapi",
    "vault"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-org/create-fastify-enterprise.git"
  },
  "author": "Your Org",
  "publishConfig": {
    "access": "public"
  }
}
